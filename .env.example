# =====================================================================
# vye-bot environment configuration
# ---------------------------------------------------------------------
# Copy this file to `.env` and fill in the values. `.env` is gitignored
# and must never be committed. Every secret the bot needs is listed here.
#
#   cp .env.example .env
#
# Values are validated on boot by src/core/config/env.ts (zod). If a
# required variable is missing or malformed, the bot refuses to start
# and prints exactly what is wrong.
# =====================================================================

# ---------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------
# One of: development | production | test
NODE_ENV=development

# Log verbosity. One of: trace | debug | info | warn | error | fatal | silent
# Optional. Defaults to "debug" in development, "info" in production.
LOG_LEVEL=debug

# Pretty-print logs with pino-pretty (true) or emit JSON lines (false).
# Optional. Defaults to true in development, false in production.
LOG_PRETTY=true

# ---------------------------------------------------------------------
# Discord (required)
# ---------------------------------------------------------------------
# Bot token from the Discord Developer Portal → your app → Bot.
DISCORD_TOKEN=

# Application (client) ID from the Developer Portal → your app → General.
# Used to register slash / context-menu commands.
DISCORD_CLIENT_ID=

# ---------------------------------------------------------------------
# Development helpers (optional)
# ---------------------------------------------------------------------
# A guild (server) ID used for *guild-scoped* command registration.
# Guild commands update instantly, so set this while developing and run
# `npm run commands:register:guild`. Leave blank to use global commands.
DEV_GUILD_ID=

# Comma-separated Discord user IDs treated as bot owners/developers.
# Example: 123456789012345678,234567890123456789
DEV_USER_IDS=

# ---------------------------------------------------------------------
# Postgres (required)
# ---------------------------------------------------------------------
# Full connection string. The bot connects on boot and FAILS FAST if the
# server is unreachable. Percent-encode reserved characters in the password
# (e.g. ! -> %21, # -> %23, @ -> %40).
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# ---------------------------------------------------------------------
# Redis (required)
# ---------------------------------------------------------------------
# Full connection string. Same fail-fast behavior as the database above.
# Example: redis://:password@host:6379/0
REDIS_URL=

# ---------------------------------------------------------------------
# Message engine (optional)
# ---------------------------------------------------------------------
# Name of the theme applied to templates that do not specify one.
# Must match a theme registered in src/core/engine/themes.ts.
DEFAULT_THEME=default
